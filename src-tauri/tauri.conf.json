{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ItsyHome",
  "version": "2.1.2",
  "identifier": "com.itsyhome.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": {
      "../resources/tray-default.png":    "tray-default.png",
      "../resources/tray-connecting.png": "tray-connecting.png",
      "../resources/tray-error.png":      "tray-error.png"
    },
    "windows": {
      "nsis": { "languages": ["English"], "installMode": "currentUser" }
    }
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ws: wss:"
    }
  }
}
